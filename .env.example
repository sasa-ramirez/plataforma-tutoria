# --- Cliente (Vite expone solo VITE_*) ---
VITE_SUPABASE_URL=https://YOUR-PROJECT.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
# Clave PÚBLICA de Web Push (notificaciones al celular). Generar con:
#   npx web-push generate-vapid-keys
VITE_VAPID_PUBLIC_KEY=

# --- Edge Function send-push (NO se exponen al cliente) ---
# supabase secrets set VAPID_PUBLIC_KEY=... VAPID_PRIVATE_KEY=...
# supabase secrets set VAPID_SUBJECT=mailto:tucorreo@dominio.com
# supabase secrets set PUSH_WEBHOOK_SECRET=<secreto-largo>


# --- Edge Function ai-review (NO se exponen al cliente) ---
# Configurar con: supabase secrets set OPENROUTER_API_KEY=...
OPENROUTER_API_KEY=sk-or-...
OPENROUTER_MODEL=anthropic/claude-3.5-sonnet
